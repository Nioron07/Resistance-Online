# GCP Service Account
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# Cloud SQL Proxy
CLOUD_SQL_PROXY_PATH=/path/to/cloud-sql-proxy
CLOUD_SQL_INSTANCE=your-project:region:instance-name

# Database connection (via Cloud SQL Proxy)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Resistance_Dashboard
DB_USER=postgres
DB_PASSWORD=your_password

# Connection pool settings
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# Application environment
NODE_ENV=development

# Public URLs used to build OAuth callback paths.
BACKEND_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:3000

# Cookie-signing secret for the Fastify session.
SESSION_SECRET=change_me_in_production

# Steam OpenID 2.0 — get a key at https://steamcommunity.com/dev/apikey
STEAM_WEB_API_KEY=

# Google OAuth 2.0 — create a "Web application" credential at
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BACKEND_BASE_URL}/auth/login/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Enable the unauthenticated /test-games dev harness. Never enable in
# production — it allows identity spoofing and unbounded room creation.
ENABLE_TEST_GAMES=false
